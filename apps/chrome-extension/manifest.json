{
  "manifest_version": 3,
  "name": "BuildMate DOM Bridge Simulator",
  "version": "0.1.0",
  "description": "Receives semantic BuildMate commands and executes them on BuildPC pages.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:8781/*"],
  "background": { "service_worker": "service-worker.js", "type": "module" },
  "content_scripts": [
    {
      "matches": [
        "https://phongvu.vn/buildpc*",
        "https://www.phongvu.vn/buildpc*",
        "http://127.0.0.1:8781/mock-buildpc"
      ],
      "js": ["dom-adapter.js", "dom-probe.js", "dev-panel.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
