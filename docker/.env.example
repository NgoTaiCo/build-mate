# Project name
PROJECT_NAME=buildmate

# OpenClaw
OPENCLAW_PORT=18789
NODE_ENV=development

# Model Provider
# Options: xiaomi-token-plan/mimo-v2.5-pro, xiaomi/mimo-v2-pro, xiaomi/mimo-v2-flash, etc
MODEL_PROVIDER=xiaomi-token-plan/mimo-v2.5-pro

# API Key cho model provider (bắt buộc)
XIAOMI_TOKEN_PLAN_API_KEY=your-api-key-here

# Gateway Auth Token — phải khớp với token trong openclaw.json.
# Chat-backend dùng chính token này để authenticate với gateway.
GATEWAY_TOKEN=your-token-here

# Session configuration
SESSION_IDLE_MINUTES=60
MEMORY_BACKEND=qmd

# ---- Chat backend (packages/chat-backend) ----
# Port HTTP cho frontend gọi POST /chat.
CHAT_BACKEND_PORT=8790

MCP_SERVER_PORT=8791
# Nguồn dữ liệu catalog cho search_components: phongvu (mặc định) | mock | live.
# live cần APIFY_API_KEY/APIFY_ACTOR_ID; không set thì fallback phongvu -> mock.
CATALOG_DATA_SOURCE=phongvu
# APIFY_API_KEY=
# APIFY_ACTOR_ID=

# Seed Ed25519 cố định (base64url 32 byte) -> deviceId ổn định, approve 1 lần.
# Tạo mới: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
OPENCLAW_DEVICE_SEED=generate-a-32-byte-base64url-seed
# Thời gian chờ tối đa một reply (ms) và agent mặc định.
REPLY_TIMEOUT_MS=60000
DEFAULT_AGENT_ID=main
