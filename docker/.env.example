# Project name
PROJECT_NAME=buildmate

# OpenClaw
OPENCLAW_PORT=18789
NODE_ENV=development

# Model Provider (mime/openai format)
# Ví dụ: mimo/mimo-pro, openai/gpt-4, ...
MODEL_PROVIDER=mimo/mimo-pro

# API Key cho model provider
# Ví dụ: từ opencode Go plan (mimo), hoặc OpenAI key
API_KEY=your-api-key-here

# Optional: Session reset (phút)
SESSION_IDLE_MINUTES=60

# Optional: Memory backend (qmd hoặc disabled)
MEMORY_BACKEND=qmd
